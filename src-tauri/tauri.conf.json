{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DJ Agent Desktop",
  "version": "0.2.0",
  "identifier": "com.djagent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DJ Agent Desktop",
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:17821; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/dj-agent-engine"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    },
    "shortDescription": "Private local music analysis and set planning for DJs",
    "longDescription": "DJ Agent Desktop analyzes local music, creates cue points and transitions, and builds event-ready setlists without cloud uploads."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCQTY0N0Y0NzVBQjhFQTIKUldTaWpxdDE5RWVtMis3NmYxbFlWWVgrNklVREg3emErTnNFeERXT0pOWmw1cWUvTjR4amtrUm4K",
      "endpoints": [
        "https://github.com/rshahoud2-png/Dj-Agent/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
